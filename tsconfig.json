{
  "compilerOptions": {
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@gigvora/sdk": [
        "./packages/sdk/src/index.ts"
      ],
      "@gigvora/sdk/*": [
        "./packages/sdk/src/*"
      ],
      "@tanstack/react-router": [
        "./src/lib/router-shim/index.tsx"
      ]
    },
    "skipLibCheck": true,
    "strictNullChecks": false
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ]
}