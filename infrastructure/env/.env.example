# ──────────────── Core ────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ──────────────── Database / cache / search / storage ────────────────
DATABASE_URL=postgres://gigvora:gigvora@localhost:5432/gigvora
REDIS_URL=redis://localhost:6379
OPENSEARCH_URL=http://localhost:9200
S3_BUCKET=gigvora-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=gigvora
S3_SECRET_KEY=gigvora-secret

# ──────────────── Auth ────────────────
JWT_SECRET=replace-with-32+char-secret-replace-me
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
LINKEDIN_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=

# ──────────────── Internal services ────────────────
ML_SERVICE_URL=http://localhost:8001
ANALYTICS_SERVICE_URL=http://localhost:8002

# ──────────────── Payments ────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PADDLE_API_KEY=

# ──────────────── Email / SMS / push ────────────────
SENDGRID_API_KEY=
MAIL_FROM=noreply@gigvora.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
EXPO_PUSH_TOKEN=

# ──────────────── AI providers (BYOK) ────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
KIMI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
PERPLEXITY_API_KEY=
STABILITY_API_KEY=
PIXABAY_API_KEY=
VEO_API_KEY=
RUNWAY_API_KEY=
ELEVENLABS_API_KEY=

# ──────────────── CRM / collab connectors ────────────────
HUBSPOT_API_KEY=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
NOTION_TOKEN=
